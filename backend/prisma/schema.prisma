generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meetings Meeting[]

  @@map("users")
}

model Meeting {
  id           String   @id @default(uuid())
  meetingTitle String
  meetingDate  DateTime
  summary      Json
  topics       Json
  decisions    Json
  actionItems  Json
  speakers     Json
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("meetings")
}
