# Usado apenas com: npm run local
# Para dev/prod na AWS as variáveis são carregadas do SSM + Secrets Manager

# Banco local
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/summarizemeets?schema=public"

# Google Gemini
GEMINI_API_KEY=sua-gemini-api-key

# Auth
JWT_SECRET=uma-string-longa-e-aleatoria

# S3 (necessário se testar upload localmente com bucket real)
S3_RECORDINGS_BUCKET=summeet-recordings-dev
AWS_REGION=us-east-1

# Porta (opcional, padrão 3000)
PORT=3000
